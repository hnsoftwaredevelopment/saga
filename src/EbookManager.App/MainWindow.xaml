<Window x:Class="EbookManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:EbookManager.App.Localization"
        xmlns:views="clr-namespace:EbookManager.App.Views"
        xmlns:viewModels="clr-namespace:EbookManager.Presentation.ViewModels;assembly=EbookManager.Presentation"
        Title="{loc:Loc AppName}"
        Width="1360"
        Height="820"
        MinWidth="1100"
        MinHeight="680"
        AllowDrop="True"
        WindowStartupLocation="CenterScreen">
  <Grid Background="{DynamicResource AppBackgroundBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="64" />
      <RowDefinition Height="56" />
      <RowDefinition Height="*" />
      <RowDefinition Height="30" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="#22000000"
            BorderThickness="0,0,0,1">
      <DockPanel Margin="16,0">
        <TextBlock Text="{loc:Loc AppName}"
                   FontSize="22"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   DockPanel.Dock="Left" />
        <StackPanel DockPanel.Dock="Left"
                    Margin="18,0,0,0"
                    VerticalAlignment="Center">
          <TextBlock Text="{Binding CurrentLibraryName}"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="{Binding CurrentLibraryPath}"
                     FontSize="11"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right">
          <Button Command="{Binding CreateLibraryCommand}"
                  Margin="6,12"
                  Padding="14,6"
                  ToolTip="{loc:Loc CreateLibraryTooltip}">
            <StackPanel Orientation="Horizontal">
              <Path Data="{StaticResource NewLibraryIconGeometry}" Fill="{DynamicResource AccentBrush}" Width="18" Height="18" Stretch="Uniform" />
              <TextBlock Text="{loc:Loc CreateLibrary}" Margin="8,0,0,0" />
            </StackPanel>
          </Button>
          <Button Command="{Binding OpenLibraryCommand}"
                  Margin="6,12"
                  Padding="14,6"
                  ToolTip="{loc:Loc OpenLibraryTooltip}">
            <StackPanel Orientation="Horizontal">
              <Path Data="{StaticResource OpenLibraryIconGeometry}" Fill="{DynamicResource AccentBrush}" Width="18" Height="18" Stretch="Uniform" />
              <TextBlock Text="{loc:Loc OpenLibrary}" Margin="8,0,0,0" />
            </StackPanel>
          </Button>
          <Button Command="{Binding AddBooksCommand}"
                  Margin="6,12"
                  Padding="14,6"
                  ToolTip="{loc:Loc AddBooks}">
            <StackPanel Orientation="Horizontal">
              <Path Data="{StaticResource AddBookIconGeometry}" Fill="{DynamicResource AccentBrush}" Width="18" Height="18" Stretch="Uniform" />
              <TextBlock Text="{loc:Loc AddBooks}" Margin="8,0,0,0" />
            </StackPanel>
          </Button>
          <Button Command="{Binding ScanFolderCommand}"
                  Margin="6,12"
                  Padding="14,6"
                  ToolTip="{loc:Loc ScanFolderTooltip}">
            <StackPanel Orientation="Horizontal">
              <Path Data="{StaticResource ScanFolderIconGeometry}" Fill="{DynamicResource AccentBrush}" Width="18" Height="18" Stretch="Uniform" />
              <TextBlock Text="{loc:Loc Scan}" Margin="8,0,0,0" />
            </StackPanel>
          </Button>
          <Button Margin="6,12"
                  Padding="14,6"
                  ToolTip="{loc:Loc OpenSettingsTooltip}"
                  Click="OpenSettingsClicked">
            <StackPanel Orientation="Horizontal">
              <Path Data="{StaticResource SettingsIconGeometry}" Fill="{DynamicResource AccentBrush}" Width="18" Height="18" Stretch="Uniform" />
              <TextBlock Text="{loc:Loc Settings}" Margin="8,0,0,0" />
            </StackPanel>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <Border Grid.Row="1"
            Padding="16,10"
            Background="{DynamicResource AppBackgroundBrush}">
      <DockPanel>
        <ComboBox SelectedValue="{Binding SelectedView}"
                  SelectedValuePath="Tag"
                  Width="180"
                  Height="32"
                  DockPanel.Dock="Left">
          <ComboBoxItem Content="{loc:Loc BookshelfView}"
                        Tag="{x:Static viewModels:LibraryView.Bookshelf}" />
          <ComboBoxItem Content="{loc:Loc DetailedView}"
                        Tag="{x:Static viewModels:LibraryView.Detailed}" />
          <ComboBoxItem Content="{loc:Loc ListView}"
                        Tag="{x:Static viewModels:LibraryView.List}" />
        </ComboBox>
        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Width="360"
                 Height="32"
                 HorizontalAlignment="Right"
                 ToolTip="{loc:Loc SearchAllFields}" />
      </DockPanel>
    </Border>

    <Grid Grid.Row="2" Margin="16,0,16,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="340" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="{DynamicResource PanelBackgroundBrush}"
              CornerRadius="16"
              Padding="14"
              Margin="0,0,12,0">
        <StackPanel>
          <TextBlock Text="{loc:Loc Filters}"
                     FontWeight="SemiBold"
                     FontSize="16"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     Margin="0,0,0,12" />
          <TextBlock Text="{loc:Loc SortBy}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     Margin="0,0,0,4" />
          <ComboBox SelectedValue="{Binding SelectedSortOption}"
                    SelectedValuePath="Tag"
                    Margin="0,0,0,12"
                    ToolTip="{loc:Loc SortLibraryTooltip}">
            <ComboBoxItem Content="{loc:Loc NoSort}"
                          Tag="{x:Static viewModels:LibrarySortOption.None}" />
            <ComboBoxItem Content="{loc:Loc Title}"
                          Tag="{x:Static viewModels:LibrarySortOption.Title}" />
            <ComboBoxItem Content="{loc:Loc Authors}"
                          Tag="{x:Static viewModels:LibrarySortOption.Author}" />
            <ComboBoxItem Content="{loc:Loc EReader}"
                          Tag="{x:Static viewModels:LibrarySortOption.EReader}" />
            <ComboBoxItem Content="{loc:Loc Tags}"
                          Tag="{x:Static viewModels:LibrarySortOption.Category}" />
          </ComboBox>
          <Expander Header="{loc:Loc Authors}" IsExpanded="True" Margin="0,0,0,6">
            <ScrollViewer MaxHeight="180"
                          VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding AuthorFilters}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <CheckBox Content="{Binding DisplayName}"
                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                              Margin="0,2"
                              Foreground="{DynamicResource TextSecondaryBrush}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Expander>
          <Expander Header="{loc:Loc Series}" Margin="0,0,0,6">
            <ScrollViewer MaxHeight="120"
                          VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding SeriesFilters}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <CheckBox Content="{Binding DisplayName}"
                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                              Margin="0,2"
                              Foreground="{DynamicResource TextSecondaryBrush}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Expander>
          <Expander Header="{loc:Loc Tags}" Margin="0,0,0,6">
            <ScrollViewer MaxHeight="120"
                          VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding CategoryFilters}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <CheckBox Content="{Binding DisplayName}"
                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                              Margin="0,2"
                              Foreground="{DynamicResource TextSecondaryBrush}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Expander>
          <Expander Header="{loc:Loc Status}" Margin="0,0,0,6">
            <ScrollViewer MaxHeight="120"
                          VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding StatusFilters}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <CheckBox Content="{Binding DisplayName}"
                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                              Margin="0,2"
                              Foreground="{DynamicResource TextSecondaryBrush}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Expander>
          <Expander Header="{loc:Loc EReader}" Margin="0,0,0,6">
            <ScrollViewer MaxHeight="120"
                          VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding EReaderFilters}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <CheckBox Content="{Binding DisplayName}"
                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                              Margin="0,2"
                              Foreground="{DynamicResource TextSecondaryBrush}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Expander>
          <Expander Header="{loc:Loc Language}" Margin="0,0,0,12">
            <ScrollViewer MaxHeight="120"
                          VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding LanguageFilters}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <CheckBox Content="{Binding DisplayName}"
                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                              Margin="0,2"
                              Foreground="{DynamicResource TextSecondaryBrush}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Expander>
          <TextBlock Text="{loc:Loc FilterHelp}"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>
      </Border>

      <Border Grid.Column="1"
              Background="{DynamicResource PanelBackgroundBrush}"
              CornerRadius="16"
              Padding="10"
              Margin="0,0,12,0"
              AllowDrop="True">
        <DockPanel LastChildFill="True">
          <Border DockPanel.Dock="Top"
                  Background="{DynamicResource AppBackgroundBrush}"
                  BorderBrush="{DynamicResource AccentBrush}"
                  BorderThickness="1"
                  CornerRadius="12"
                  Padding="12"
                  Margin="0,0,0,10">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding ImportJob.IsVisible, Mode=OneWay}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding ImportJob.Title, Mode=OneWay}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="{Binding ImportJob.StatusText, Mode=OneWay}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,2,0,8" />
                <ProgressBar Height="8"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding ImportJob.ProgressValue, Mode=OneWay}"
                             IsIndeterminate="{Binding ImportJob.IsIndeterminate, Mode=OneWay}" />
                <DockPanel Margin="0,8,0,0">
                  <TextBlock Text="{Binding ImportJob.ProgressText, Mode=OneWay}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             DockPanel.Dock="Left" />
                  <TextBlock HorizontalAlignment="Right"
                             Foreground="{DynamicResource TextSecondaryBrush}">
                    <Run Text="{loc:Loc ImportAdded}" />
                    <Run Text=": " />
                    <Run Text="{Binding ImportJob.AddedCount, Mode=OneWay}" />
                    <Run Text="  |  " />
                    <Run Text="{loc:Loc ImportDuplicates}" />
                    <Run Text=": " />
                    <Run Text="{Binding ImportJob.DuplicateCount, Mode=OneWay}" />
                    <Run Text="  |  " />
                    <Run Text="{loc:Loc ImportFailed}" />
                    <Run Text=": " />
                    <Run Text="{Binding ImportJob.FailedCount, Mode=OneWay}" />
                  </TextBlock>
                </DockPanel>
              </StackPanel>
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          VerticalAlignment="Top"
                          Margin="12,0,0,0">
                <Button Content="{loc:Loc Details}"
                        Command="{Binding ShowImportDetailsCommand}"
                        IsEnabled="{Binding ImportJob.CanShowDetails, Mode=OneWay}"
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="{loc:Loc Cancel}"
                        Command="{Binding CancelImportCommand}"
                        Padding="12,6">
                  <Button.Style>
                    <Style TargetType="Button">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding ImportJob.IsActive, Mode=OneWay}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
                <Button Content="{loc:Loc Close}"
                        Command="{Binding CloseImportJobCommand}"
                        Padding="12,6">
                  <Button.Style>
                    <Style TargetType="Button">
                      <Setter Property="Visibility" Value="Visible" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding ImportJob.IsActive, Mode=OneWay}" Value="True">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
              </StackPanel>
            </Grid>
          </Border>

          <Grid>
          <Border Background="{DynamicResource PanelBackgroundBrush}"
                  Panel.ZIndex="1">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding VisibleBookCount}" Value="0">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="420">
              <ProgressBar Height="8"
                           Margin="0,0,0,16"
                           Minimum="0"
                           Maximum="100"
                           Value="{Binding LoadingLibraryProgressValue, Mode=OneWay}"
                           IsIndeterminate="{Binding IsLoadingLibraryProgressIndeterminate, Mode=OneWay}">
                <ProgressBar.Style>
                  <Style TargetType="ProgressBar">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsLoadingLibrary}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </ProgressBar.Style>
              </ProgressBar>
              <TextBlock Text="{Binding LoadingLibraryProgressText, Mode=OneWay}"
                         FontSize="13"
                         TextAlignment="Center"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         Margin="0,-8,0,12">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsLoadingLibraryProgressIndeterminate}" Value="False">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
              <TextBlock Text="{Binding EmptyStateMessage}"
                         FontSize="18"
                         FontWeight="SemiBold"
                         TextAlignment="Center"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         Margin="0,0,0,16" />
              <StackPanel Orientation="Horizontal"
                          HorizontalAlignment="Center">
                <StackPanel.Style>
                  <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsLoadingLibrary}" Value="True">
                        <Setter Property="Visibility" Value="Collapsed" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </StackPanel.Style>
                <Button Content="{loc:Loc AddBooks}"
                        Command="{Binding AddBooksCommand}"
                        Padding="16,8"
                        Margin="0,0,8,0" />
                <Button Content="{loc:Loc Scan}"
                        Command="{Binding ScanFolderCommand}"
                        Padding="16,8"
                        Margin="0,0,8,0" />
                <Button Content="{loc:Loc CreateLibrary}"
                        Command="{Binding CreateLibraryCommand}"
                        Padding="16,8"
                        Margin="0,0,8,0" />
                <Button Content="{loc:Loc OpenLibrary}"
                        Command="{Binding OpenLibraryCommand}"
                        Padding="16,8" />
              </StackPanel>
            </StackPanel>
          </Border>
          <views:BookshelfView>
            <views:BookshelfView.Style>
              <Style TargetType="views:BookshelfView">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding SelectedView}" Value="Bookshelf">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </views:BookshelfView.Style>
          </views:BookshelfView>
          <views:DetailedGridView>
            <views:DetailedGridView.Style>
              <Style TargetType="views:DetailedGridView">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding SelectedView}" Value="Detailed">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </views:DetailedGridView.Style>
          </views:DetailedGridView>
          <views:LibraryListView>
            <views:LibraryListView.Style>
              <Style TargetType="views:LibraryListView">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding SelectedView}" Value="List">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </views:LibraryListView.Style>
          </views:LibraryListView>
          </Grid>
        </DockPanel>
      </Border>

      <Border Grid.Column="2"
              Background="{DynamicResource PanelBackgroundBrush}"
              CornerRadius="16">
        <views:BookDetailsView DataContext="{Binding Details}" />
      </Border>
    </Grid>

    <Border Grid.Row="3"
            Padding="16,0"
            Background="{DynamicResource PanelBackgroundBrush}">
      <DockPanel>
        <TextBlock VerticalAlignment="Center"
                   Foreground="{DynamicResource TextSecondaryBrush}">
          <Run Text="{loc:Loc BookCount}" />
          <Run Text=": " />
          <Run Text="{Binding VisibleBookCount, Mode=OneWay}" />
        </TextBlock>
        <TextBlock HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextSecondaryBrush}">
          <Run Text="{loc:Loc AppVersion}" />
          <Run Text=" 26.6" />
        </TextBlock>
      </DockPanel>
    </Border>
  </Grid>
</Window>
