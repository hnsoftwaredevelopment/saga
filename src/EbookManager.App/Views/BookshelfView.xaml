<UserControl x:Class="EbookManager.App.Views.BookshelfView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:EbookManager.App.Converters"
             AllowDrop="True">
  <UserControl.Resources>
    <converters:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSourceConverter" />
  </UserControl.Resources>
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                AllowDrop="True">
    <ListBox ItemsSource="{Binding VisibleBooks}"
             SelectedItem="{Binding SelectedBook, Mode=TwoWay}"
             BorderThickness="0"
             Background="Transparent"
             AllowDrop="True">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel />
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Width="150"
                  Margin="10"
                  Padding="10"
                  Background="{DynamicResource PanelBackgroundBrush}"
                  CornerRadius="14">
            <StackPanel>
              <Border Height="190"
                      Background="#FFE2E8F0"
                      CornerRadius="10"
                      Margin="0,0,0,10">
                <Grid>
                  <TextBlock Text="Cover"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                  <Image Source="{Binding CoverBytes, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                         Stretch="UniformToFill" />
                </Grid>
              </Border>
              <TextBlock Text="{Binding Title}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap"
                         MaxHeight="40"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="{Binding Authors}"
                         TextWrapping="Wrap"
                         MaxHeight="40"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </ScrollViewer>
</UserControl>
