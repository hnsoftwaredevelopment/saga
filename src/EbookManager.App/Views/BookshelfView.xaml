<UserControl x:Class="EbookManager.App.Views.BookshelfView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:EbookManager.App.Controls"
             xmlns:converters="clr-namespace:EbookManager.App.Converters"
             xmlns:loc="clr-namespace:EbookManager.App.Localization"
             AllowDrop="True">
  <UserControl.Resources>
    <converters:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSourceConverter" />
    <converters:FilePathToImageSourceConverter x:Key="FilePathToImageSourceConverter" />
  </UserControl.Resources>
  <ListBox ItemsSource="{Binding VisibleBooks}"
           SelectedItem="{Binding SelectedBook, Mode=TwoWay}"
           BorderThickness="0"
           Background="Transparent"
           AllowDrop="True"
           ScrollViewer.HorizontalScrollBarVisibility="Disabled"
           ScrollViewer.VerticalScrollBarVisibility="Auto">
    <ListBox.ItemsPanel>
      <ItemsPanelTemplate>
        <WrapPanel IsItemsHost="True" />
      </ItemsPanelTemplate>
    </ListBox.ItemsPanel>
    <ListBox.ItemTemplate>
      <DataTemplate>
        <Border Width="150"
                Margin="10"
                Padding="10"
                Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="14">
          <StackPanel>
            <Border Height="190"
                    Background="#FFE2E8F0"
                    CornerRadius="10"
                    Margin="0,0,0,10">
              <Grid>
                <TextBlock Text="{loc:Loc Cover}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <Image Source="{Binding CoverPath, Converter={StaticResource FilePathToImageSourceConverter}, ConverterParameter=220}"
                       Stretch="UniformToFill" />
              </Grid>
            </Border>
            <controls:HighlightedTextBlock HighlightedText="{Binding Title}"
                                           SearchText="{Binding SearchText}"
                                           HighlightBrush="{DynamicResource SearchHighlightBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           MaxHeight="40"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
            <controls:HighlightedTextBlock HighlightedText="{Binding Authors}"
                                           SearchText="{Binding SearchText}"
                                           HighlightBrush="{DynamicResource SearchHighlightBrush}"
                                           TextWrapping="Wrap"
                                           MaxHeight="40"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
        </Border>
      </DataTemplate>
    </ListBox.ItemTemplate>
  </ListBox>
</UserControl>
