<Window x:Class="EbookManager.App.Views.DuplicateCandidateDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:EbookManager.App.Converters"
        xmlns:loc="clr-namespace:EbookManager.App.Localization"
        Title="{Binding Title}"
        Width="760"
        Height="560"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <converters:FilePathToImageSourceConverter x:Key="FilePathToImageSourceConverter" />
  </Window.Resources>
  <DockPanel Margin="18">
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Content="{loc:Loc Close}"
              MinWidth="90"
              Click="CloseClicked" />
    </StackPanel>

    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Height="300"
              Background="#FFE2E8F0"
              CornerRadius="12"
              Margin="0,0,18,0"
              VerticalAlignment="Top">
        <Grid>
          <TextBlock Text="{loc:Loc Cover}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <Image Source="{Binding CoverPath, Converter={StaticResource FilePathToImageSourceConverter}, ConverterParameter=320}"
                 Stretch="Uniform" />
        </Grid>
      </Border>

      <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <TextBlock Text="{Binding Title}"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     TextWrapping="Wrap"
                     Margin="0,0,0,6" />
          <TextBlock Text="{Binding Authors}"
                     FontSize="14"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Margin="0,0,0,16" />

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Loc Series}" FontWeight="SemiBold" Margin="0,0,12,8" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Series}" TextWrapping="Wrap" Margin="0,0,0,8" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Loc SeriesNumber}" FontWeight="SemiBold" Margin="0,0,12,8" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SeriesNumber}" TextWrapping="Wrap" Margin="0,0,0,8" />
            <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Loc Language}" FontWeight="SemiBold" Margin="0,0,12,8" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Language}" TextWrapping="Wrap" Margin="0,0,0,8" />
            <TextBlock Grid.Row="3" Grid.Column="0" Text="{loc:Loc Publisher}" FontWeight="SemiBold" Margin="0,0,12,8" />
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Publisher}" TextWrapping="Wrap" Margin="0,0,0,8" />
            <TextBlock Grid.Row="4" Grid.Column="0" Text="{loc:Loc PublicationDate}" FontWeight="SemiBold" Margin="0,0,12,8" />
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PublicationDate}" TextWrapping="Wrap" Margin="0,0,0,8" />
            <TextBlock Grid.Row="5" Grid.Column="0" Text="{loc:Loc Isbn}" FontWeight="SemiBold" Margin="0,0,12,8" />
            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Isbn}" TextWrapping="Wrap" Margin="0,0,0,8" />
            <TextBlock Grid.Row="6" Grid.Column="0" Text="{loc:Loc Tags}" FontWeight="SemiBold" Margin="0,0,12,8" />
            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Tags}" TextWrapping="Wrap" Margin="0,0,0,8" />
          </Grid>

          <TextBlock Text="{loc:Loc Description}" FontWeight="SemiBold" Margin="0,10,0,4" />
          <TextBox Text="{Binding Description, Mode=OneWay}"
                   IsReadOnly="True"
                   BorderThickness="0"
                   Background="Transparent"
                   TextWrapping="Wrap"
                   AcceptsReturn="True"
                   MinHeight="140" />
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </DockPanel>
</Window>
