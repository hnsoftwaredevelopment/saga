<Window x:Class="EbookManager.App.Views.DuplicateMergePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:EbookManager.App.Converters"
        xmlns:loc="clr-namespace:EbookManager.App.Localization"
        xmlns:viewModels="clr-namespace:EbookManager.Presentation.ViewModels;assembly=EbookManager.Presentation"
        Title="{loc:Loc DuplicateMergePreviewTitle}"
        Width="1080"
        Height="720"
        MinWidth="960"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <converters:FilePathToImageSourceConverter x:Key="FilePathToImageSourceConverter" />
    <converters:LocalizationKeyToStringConverter x:Key="LocalizationKeyToStringConverter" />

    <Style x:Key="MergePreviewHeaderTextStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="MergePreviewValueTextStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="MergeActionButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="6" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="ToolTip" Value="{loc:Loc MergeActionNoAction}" />
      <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsActionEnabled}" Value="False">
          <Setter Property="ToolTip" Value="{loc:Loc MergeActionDisabledSameValue}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Action}" Value="{x:Static viewModels:DuplicateMergeFieldAction.Copy}">
          <Setter Property="ToolTip" Value="{loc:Loc MergeActionCopy}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Action}" Value="{x:Static viewModels:DuplicateMergeFieldAction.Merge}">
          <Setter Property="ToolTip" Value="{loc:Loc MergeActionMerge}" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="MergeActionIconStyle" TargetType="Path">
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
      <Setter Property="Stretch" Value="Uniform" />
      <Setter Property="StrokeThickness" Value="3" />
      <Setter Property="Stroke" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="Fill" Value="Transparent" />
      <Setter Property="Data" Value="{StaticResource MergePreviewNoActionIconGeometry}" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding Action}" Value="{x:Static viewModels:DuplicateMergeFieldAction.Copy}">
          <Setter Property="Width" Value="20" />
          <Setter Property="Height" Value="20" />
          <Setter Property="Stroke" Value="Transparent" />
          <Setter Property="Fill" Value="#AA0000" />
          <Setter Property="Data" Value="{StaticResource MergePreviewCopyIconGeometry}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Action}" Value="{x:Static viewModels:DuplicateMergeFieldAction.Merge}">
          <Setter Property="Width" Value="20" />
          <Setter Property="Height" Value="20" />
          <Setter Property="Stroke" Value="Transparent" />
          <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
          <Setter Property="Data" Value="{StaticResource MergePreviewMergeIconGeometry}" />
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <DockPanel Margin="18">
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
      <DockPanel>
        <Button DockPanel.Dock="Right"
                Width="46"
                Height="38"
                Command="{Binding SwapDirectionCommand}"
                ToolTip="{loc:Loc SwapMergeDirectionTooltip}">
          <Path Width="22"
                Height="22"
                Stretch="Uniform"
                Fill="{DynamicResource AccentBrush}"
                Data="{StaticResource MergePreviewSwapDirectionIconGeometry}" />
        </Button>
        <StackPanel>
          <TextBlock Text="{loc:Loc DuplicateMergePreviewTitle}"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="{loc:Loc DuplicateMergePreviewHelp}"
                     Margin="0,6,16,0"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </DockPanel>
    </StackPanel>

    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,14,0,0">
      <Button Content="{loc:Loc Cancel}"
              MinWidth="100"
              Margin="0,0,8,0"
              IsCancel="True" />
      <Button Content="{loc:Loc LinkFormat}"
              MinWidth="150"
              IsDefault="True"
              Click="LinkFormatClicked" />
    </StackPanel>

    <Border Padding="14"
            CornerRadius="12"
            Background="{DynamicResource PanelBackgroundBrush}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="130" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="54" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="1"
                   Text="{loc:Loc MergeTargetBook}"
                   Style="{StaticResource MergePreviewHeaderTextStyle}" />
        <TextBlock Grid.Column="3"
                   Text="{loc:Loc MergeSourceBook}"
                   Style="{StaticResource MergePreviewHeaderTextStyle}" />

        <ScrollViewer Grid.Row="1"
                      Grid.ColumnSpan="4"
                      Margin="0,12,0,0"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <ItemsControl ItemsSource="{Binding Rows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,0,8">
                    <Grid.Style>
                      <Style TargetType="Grid">
                        <Setter Property="MinHeight" Value="36" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsLargeText}" Value="True">
                            <Setter Property="MinHeight" Value="132" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsCover}" Value="True">
                            <Setter Property="MinHeight" Value="166" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="130" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="54" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Label, Converter={StaticResource LocalizationKeyToStringConverter}}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Top"
                               Margin="0,8,12,0" />
                    <Border Grid.Column="1"
                            Padding="10,7"
                            CornerRadius="7"
                            Background="{DynamicResource AppBackgroundBrush}">
                      <Grid>
                        <TextBlock Text="{Binding TargetValue}">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MergePreviewValueTextStyle}">
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCover}" Value="True">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                        <Image Width="112"
                               Height="156"
                               HorizontalAlignment="Left"
                               Source="{Binding TargetImagePath, Converter={StaticResource FilePathToImageSourceConverter}, ConverterParameter=180}"
                               Stretch="UniformToFill">
                          <Image.Style>
                            <Style TargetType="Image">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCover}" Value="True">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Image.Style>
                        </Image>
                      </Grid>
                    </Border>
                    <Button Grid.Column="2"
                            Command="{Binding CycleActionCommand}"
                            Style="{StaticResource MergeActionButtonStyle}">
                      <Path Style="{StaticResource MergeActionIconStyle}" />
                    </Button>
                    <Border Grid.Column="3"
                            Padding="10,7"
                            CornerRadius="7"
                            Background="{DynamicResource AppBackgroundBrush}">
                      <Grid>
                        <TextBlock Text="{Binding SourceValue}">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MergePreviewValueTextStyle}">
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCover}" Value="True">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                        <Image Width="112"
                               Height="156"
                               HorizontalAlignment="Left"
                               Source="{Binding SourceImagePath, Converter={StaticResource FilePathToImageSourceConverter}, ConverterParameter=180}"
                               Stretch="UniformToFill">
                          <Image.Style>
                            <Style TargetType="Image">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCover}" Value="True">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Image.Style>
                        </Image>
                      </Grid>
                    </Border>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Border>
  </DockPanel>
</Window>
