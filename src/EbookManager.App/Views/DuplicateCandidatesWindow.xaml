<Window x:Class="EbookManager.App.Views.DuplicateCandidatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:EbookManager.App.Localization"
        Title="{loc:Loc DuplicateCandidates}"
        Width="880"
        Height="560"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="18">
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
      <TextBlock Text="{loc:Loc DuplicateCandidates}"
                 FontSize="20"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                 Margin="0,4,0,0">
        <Run Text="{Binding GroupCount, Mode=OneWay}" />
        <Run Text="{loc:Loc DuplicateCandidateGroupsSuffix}" />
        <Run Text=", " />
        <Run Text="{Binding BookCount, Mode=OneWay}" />
        <Run Text="{loc:Loc DuplicateCandidateBooksSuffix}" />
      </TextBlock>
    </StackPanel>

    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Content="{loc:Loc Close}"
              MinWidth="90"
              Click="CloseClicked" />
    </StackPanel>

    <Grid>
      <TextBlock Text="{loc:Loc DuplicateCandidatesNone}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Foreground="{DynamicResource TextSecondaryBrush}">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasGroups}" Value="False">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>

      <TreeView ItemsSource="{Binding Groups}">
        <TreeView.Style>
          <Style TargetType="TreeView">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasGroups}" Value="False">
                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TreeView.Style>
        <TreeView.ItemTemplate>
          <HierarchicalDataTemplate ItemsSource="{Binding Books}">
            <TextBlock Text="{Binding Header}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <HierarchicalDataTemplate.ItemTemplate>
              <DataTemplate>
                <Grid Margin="18,4,0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="90" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{Binding Title}" />
                  <TextBlock Grid.Column="1" Text="{Binding Authors}" Margin="12,0,0,0" />
                  <TextBlock Grid.Column="2" Text="{Binding Series}" Margin="12,0,0,0" />
                  <TextBlock Grid.Column="3" Text="{Binding Language}" Margin="12,0,0,0" />
                </Grid>
              </DataTemplate>
            </HierarchicalDataTemplate.ItemTemplate>
          </HierarchicalDataTemplate>
        </TreeView.ItemTemplate>
      </TreeView>
    </Grid>
  </DockPanel>
</Window>
