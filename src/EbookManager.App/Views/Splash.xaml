<Window x:Class="EbookManager.App.Views.Splash"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Splash"
        Height="265"
        Width="800"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
  <Grid>
    <Image HorizontalAlignment="Left"
           Height="265"
           Margin="0"
           VerticalAlignment="Top"
           Width="800"
           Source="/EbookManager;component/Resources/Splash/SplashBase.png" />

    <StackPanel Orientation="Horizontal"
                Margin="10,10,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top">
      <Label Content="Saga"
             FontSize="62"
             VerticalAlignment="Bottom"
             Margin="0,0,15,0"
             Foreground="AntiqueWhite"
             FontFamily="Segoe UI Variable Display Bold"
             Cursor="None"
             IsEnabled="False" />
      <Label x:Name="SubtitleText"
             FontSize="36"
             VerticalAlignment="Bottom"
             Margin="0,0,0,5"
             Foreground="DarkOrange"
             FontFamily="Segoe UI Variable Display Semibold"
             Cursor="None"
             IsEnabled="False" />
    </StackPanel>

    <Image x:Name="AppLogoImage"
           Width="96"
           Height="96"
           HorizontalAlignment="Right"
           VerticalAlignment="Bottom"
           Margin="0,0,14,14"
           Stretch="Uniform"
           Source="/EbookManager;component/Resources/AppIcon/appicon.png" />

    <Grid Width="430"
          HorizontalAlignment="Left"
          VerticalAlignment="Bottom"
          Margin="14,0,0,16">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock x:Name="StatusText"
                 Grid.Column="0"
                 FontSize="13"
                 Foreground="AntiqueWhite" />
      <TextBlock Text="{Binding LoadingLibraryProgressText, Mode=OneWay}"
                 Grid.Column="1"
                 Margin="18,0,0,0"
                 FontSize="13"
                 Foreground="AntiqueWhite" />

      <ProgressBar Grid.Row="1"
                   Grid.ColumnSpan="2"
                   Height="6"
                   Margin="0,7,0,8"
                   Minimum="0"
                   Maximum="100"
                   Value="{Binding LoadingLibraryProgressValue, Mode=OneWay}"
                   IsIndeterminate="{Binding IsLoadingLibraryProgressIndeterminate, Mode=OneWay}"
                   Foreground="DarkOrange"
                   Background="#55FAEBD7"
                   BorderThickness="0" />

      <TextBlock x:Name="VersionText"
                 Grid.Row="2"
                 Grid.ColumnSpan="2"
                 FontSize="12"
                 Foreground="AntiqueWhite"
                 Opacity="0.85" />
    </Grid>
  </Grid>
</Window>
