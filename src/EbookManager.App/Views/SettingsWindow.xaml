<Window x:Class="EbookManager.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:EbookManager.App.Localization"
        xmlns:settings="clr-namespace:EbookManager.Domain.Settings;assembly=EbookManager.Domain"
        Title="{loc:Loc Settings}"
        Width="560"
        Height="430"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TabControl Grid.Row="0">
      <TabItem Header="{loc:Loc SettingsGeneralSection}">
        <Grid Margin="12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <TextBlock Text="{loc:Loc Culture}" Grid.Row="0" FontWeight="SemiBold" Margin="0,0,12,12" />
          <ComboBox Grid.Row="0"
                    Grid.Column="1"
                    ItemsSource="{Binding SelectableCultures}"
                    DisplayMemberPath="DisplayName"
                    SelectedValue="{Binding Culture}"
                    SelectedValuePath="Value"
                    SelectionChanged="CultureSelectionChanged"
                    Margin="0,0,0,12" />
        </Grid>
      </TabItem>

      <TabItem Header="{loc:Loc SettingsAppearanceSection}">
        <Grid Margin="12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <TextBlock Text="{loc:Loc Theme}" Grid.Row="0" FontWeight="SemiBold" Margin="0,0,12,12" />
          <ComboBox Grid.Row="0"
                    Grid.Column="1"
                    ItemsSource="{Binding SelectableThemes}"
                    SelectedItem="{Binding Theme}"
                    SelectionChanged="ThemeSelectionChanged"
                    Margin="0,0,0,12" />

          <TextBlock Text="{loc:Loc DefaultView}" Grid.Row="1" FontWeight="SemiBold" Margin="0,0,12,12" />
          <ComboBox Grid.Row="1"
                    Grid.Column="1"
                    SelectedValue="{Binding DefaultView}"
                    SelectedValuePath="Tag"
                    SelectionChanged="DefaultViewSelectionChanged"
                    Margin="0,0,0,12">
            <ComboBoxItem Content="{loc:Loc BookshelfView}" Tag="Bookshelf" />
            <ComboBoxItem Content="{loc:Loc DetailedView}" Tag="Detailed" />
            <ComboBoxItem Content="{loc:Loc ListView}" Tag="List" />
          </ComboBox>
        </Grid>
      </TabItem>

      <TabItem Header="{loc:Loc SettingsImportSection}">
        <StackPanel Margin="12">
          <CheckBox Content="{loc:Loc IncludeScanSubdirectoriesSetting}"
                    IsChecked="{Binding IncludeScanSubdirectories}"
                    Margin="0,0,0,12" />
        </StackPanel>
      </TabItem>

      <TabItem Header="{loc:Loc SettingsMetadataSection}">
        <Grid Margin="12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <TextBlock Text="{loc:Loc AuthorSortStrategy}" Grid.Row="0" FontWeight="SemiBold" Margin="0,0,12,12" />
          <ComboBox Grid.Row="0" Grid.Column="1" SelectedValue="{Binding AuthorSortStrategy}" SelectedValuePath="Tag" Margin="0,0,0,12">
            <ComboBoxItem Content="{loc:Loc AuthorSortDisplayName}" Tag="{x:Static settings:AuthorSortStrategy.DisplayName}" />
            <ComboBoxItem Content="{loc:Loc AuthorSortLastNameFirst}" Tag="{x:Static settings:AuthorSortStrategy.LastNameFirst}" />
            <ComboBoxItem Content="{loc:Loc AuthorSortLastNameFirstDutchPrefixes}" Tag="{x:Static settings:AuthorSortStrategy.LastNameFirstDutchPrefixes}" />
          </ComboBox>

          <TextBlock Text="{loc:Loc NormalizeLanguageMetadata}"
                     Grid.Row="1"
                     FontWeight="SemiBold"
                     Margin="0,0,12,12" />
          <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
            <TextBlock Text="{loc:Loc NormalizeLanguageMetadataDescription}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,8" />
            <Button Content="{loc:Loc NormalizeLanguageMetadata}"
                    MinWidth="150"
                    HorizontalAlignment="Left"
                    Click="NormalizeLanguageMetadataClicked" />
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="{loc:Loc SettingsConfirmationsSection}">
        <StackPanel Margin="12">
          <CheckBox Content="{loc:Loc ConfirmDeleteSetting}"
                    IsChecked="{Binding ConfirmDelete}"
                    Margin="0,0,0,12" />
        </StackPanel>
      </TabItem>

      <TabItem Header="{loc:Loc SettingsDuplicatesSection}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
          <CheckBox Content="{loc:Loc DuplicateExactMatchesOnlySetting}"
                    IsChecked="{Binding DuplicateExactMatchesOnly}"
                    Margin="0,0,0,8" />
          <TextBlock Text="{loc:Loc DuplicateExactMatchesOnlyDescription}"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     Margin="0,0,0,16" />
          <TextBlock Text="{loc:Loc DuplicateMergeDefaults}"
                     FontWeight="SemiBold"
                     Margin="0,0,0,6" />
          <TextBlock Text="{loc:Loc DuplicateMergeDefaultsDescription}"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     Margin="0,0,0,12" />
          <UniformGrid Columns="2" Margin="0,0,0,8">
            <StackPanel Margin="0,0,12,10">
              <TextBlock Text="{loc:Loc Cover}" FontWeight="SemiBold" Margin="0,0,0,4" />
              <ComboBox SelectedValue="{Binding MergeDefaultCover}" SelectedValuePath="Tag">
                <ComboBoxItem Content="{loc:Loc MergeActionNoAction}" Tag="{x:Static settings:DuplicateMergeDefaultAction.NoAction}" />
                <ComboBoxItem Content="{loc:Loc MergeActionCopy}" Tag="{x:Static settings:DuplicateMergeDefaultAction.Copy}" />
              </ComboBox>
            </StackPanel>
            <StackPanel Margin="0,0,0,10">
              <TextBlock Text="{loc:Loc Authors}" FontWeight="SemiBold" Margin="0,0,0,4" />
              <ComboBox SelectedValue="{Binding MergeDefaultAuthors}" SelectedValuePath="Tag">
                <ComboBoxItem Content="{loc:Loc MergeActionNoAction}" Tag="{x:Static settings:DuplicateMergeDefaultAction.NoAction}" />
                <ComboBoxItem Content="{loc:Loc MergeActionCopy}" Tag="{x:Static settings:DuplicateMergeDefaultAction.Copy}" />
                <ComboBoxItem Content="{loc:Loc MergeActionMerge}" Tag="{x:Static settings:DuplicateMergeDefaultAction.Merge}" />
              </ComboBox>
            </StackPanel>
            <StackPanel Margin="0,0,12,10">
              <TextBlock Text="{loc:Loc Tags}" FontWeight="SemiBold" Margin="0,0,0,4" />
              <ComboBox SelectedValue="{Binding MergeDefaultTags}" SelectedValuePath="Tag">
                <ComboBoxItem Content="{loc:Loc MergeActionNoAction}" Tag="{x:Static settings:DuplicateMergeDefaultAction.NoAction}" />
                <ComboBoxItem Content="{loc:Loc MergeActionCopy}" Tag="{x:Static settings:DuplicateMergeDefaultAction.Copy}" />
                <ComboBoxItem Content="{loc:Loc MergeActionMerge}" Tag="{x:Static settings:DuplicateMergeDefaultAction.Merge}" />
              </ComboBox>
            </StackPanel>
            <StackPanel Margin="0,0,0,10">
              <TextBlock Text="{loc:Loc Description}" FontWeight="SemiBold" Margin="0,0,0,4" />
              <ComboBox SelectedValue="{Binding MergeDefaultDescription}" SelectedValuePath="Tag">
                <ComboBoxItem Content="{loc:Loc MergeActionNoAction}" Tag="{x:Static settings:DuplicateMergeDefaultAction.NoAction}" />
                <ComboBoxItem Content="{loc:Loc MergeActionCopy}" Tag="{x:Static settings:DuplicateMergeDefaultAction.Copy}" />
                <ComboBoxItem Content="{loc:Loc MergeActionMerge}" Tag="{x:Static settings:DuplicateMergeDefaultAction.Merge}" />
              </ComboBox>
            </StackPanel>
            <StackPanel Margin="0,0,12,10">
              <TextBlock Text="{loc:Loc Publisher}" FontWeight="SemiBold" Margin="0,0,0,4" />
              <ComboBox SelectedValue="{Binding MergeDefaultPublisher}" SelectedValuePath="Tag">
                <ComboBoxItem Content="{loc:Loc MergeActionNoAction}" Tag="{x:Static settings:DuplicateMergeDefaultAction.NoAction}" />
                <ComboBoxItem Content="{loc:Loc MergeActionCopy}" Tag="{x:Static settings:DuplicateMergeDefaultAction.Copy}" />
              </ComboBox>
            </StackPanel>
            <StackPanel Margin="0,0,0,10">
              <TextBlock Text="{loc:Loc Language}" FontWeight="SemiBold" Margin="0,0,0,4" />
              <ComboBox SelectedValue="{Binding MergeDefaultLanguage}" SelectedValuePath="Tag">
                <ComboBoxItem Content="{loc:Loc MergeActionNoAction}" Tag="{x:Static settings:DuplicateMergeDefaultAction.NoAction}" />
                <ComboBoxItem Content="{loc:Loc MergeActionCopy}" Tag="{x:Static settings:DuplicateMergeDefaultAction.Copy}" />
              </ComboBox>
            </StackPanel>
          </UniformGrid>
        </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="{loc:Loc SettingsDiagnosticsSection}">
        <StackPanel Margin="12">
          <CheckBox Content="{loc:Loc EnableDiagnosticDetailsSetting}"
                    IsChecked="{Binding EnableDiagnosticDetails}"
                    Margin="0,0,0,8" />
          <TextBlock Text="{loc:Loc EnableDiagnosticDetailsDescription}"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>
      </TabItem>
    </TabControl>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Content="{loc:Loc Save}" MinWidth="90" Margin="0,0,8,0" Click="SaveClicked" />
      <Button Content="{loc:Loc Cancel}" MinWidth="90" Click="CancelClicked" />
    </StackPanel>
  </Grid>
</Window>
