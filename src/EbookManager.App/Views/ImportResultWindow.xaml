<Window x:Class="EbookManager.App.Views.ImportResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import results"
        Width="880"
        Height="560"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="18">
    <StackPanel DockPanel.Dock="Top"
                Margin="0,0,0,14">
      <TextBlock Text="Import results"
                 FontSize="20"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <TextBlock Text="{Binding SummaryText}"
                 Margin="0,4,0,12"
                 Foreground="{DynamicResource TextSecondaryBrush}" />
      <UniformGrid Columns="5">
        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="10" Padding="10" Margin="0,0,8,0">
          <StackPanel>
            <TextBlock Text="{Binding TotalCount}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Total" Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
        </Border>
        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="10" Padding="10" Margin="0,0,8,0">
          <StackPanel>
            <TextBlock Text="{Binding AddedCount}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Added" Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
        </Border>
        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="10" Padding="10" Margin="0,0,8,0">
          <StackPanel>
            <TextBlock Text="{Binding ExactDuplicateCount}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Duplicates" Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
        </Border>
        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="10" Padding="10" Margin="0,0,8,0">
          <StackPanel>
            <TextBlock Text="{Binding PossibleDuplicateCount}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Possible" Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
        </Border>
        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="10" Padding="10">
          <StackPanel>
            <TextBlock Text="{Binding FailedCount}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Failed" Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
        </Border>
      </UniformGrid>
    </StackPanel>
    <Button Content="Close"
            DockPanel.Dock="Bottom"
            HorizontalAlignment="Right"
            MinWidth="90"
            Margin="0,12,0,0"
            Click="CloseClicked" />
    <DataGrid ItemsSource="{Binding Items}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column">
      <DataGrid.Columns>
        <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="220">
          <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
              <Setter Property="ToolTip" Value="{Binding SourcePath}" />
              <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>
          </DataGridTextColumn.ElementStyle>
        </DataGridTextColumn>
        <DataGridTextColumn Header="Outcome" Binding="{Binding OutcomeLabel}" Width="160" />
        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="2*" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>
