<Window x:Class="EbookManager.App.Views.ImportResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:EbookManager.App.Converters"
        xmlns:loc="clr-namespace:EbookManager.App.Localization"
        xmlns:viewModels="clr-namespace:EbookManager.Presentation.ViewModels;assembly=EbookManager.Presentation"
        Title="{loc:Loc ImportResults}"
        Width="880"
        Height="560"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <converters:ImportOutcomeToLocalizedStringConverter x:Key="ImportOutcomeToLocalizedStringConverter" />
    <converters:ImportMessageToLocalizedStringConverter x:Key="ImportMessageToLocalizedStringConverter" />
  </Window.Resources>
  <DockPanel Margin="18">
    <StackPanel DockPanel.Dock="Top"
                Margin="0,0,0,14">
      <TextBlock Text="{loc:Loc ImportResults}"
                 FontSize="20"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <TextBlock Text="{Binding SummaryText}"
                 Margin="0,4,0,12"
                 Foreground="{DynamicResource TextSecondaryBrush}" />
      <UniformGrid Columns="5">
        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="10" Padding="10" Margin="0,0,8,0">
          <StackPanel>
            <TextBlock Text="{Binding TotalCount}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="{loc:Loc ImportTotal}" Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
        </Border>
        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="10" Padding="10" Margin="0,0,8,0">
          <StackPanel>
            <TextBlock Text="{Binding AddedCount}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="{loc:Loc ImportAdded}" Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
        </Border>
        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="10" Padding="10" Margin="0,0,8,0">
          <StackPanel>
            <TextBlock Text="{Binding ExactDuplicateCount}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="{loc:Loc ImportDuplicates}" Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
        </Border>
        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="10" Padding="10" Margin="0,0,8,0">
          <StackPanel>
            <TextBlock Text="{Binding PossibleDuplicateCount}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="{loc:Loc ImportPossibleShort}" Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
        </Border>
        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="10" Padding="10">
          <StackPanel>
            <TextBlock Text="{Binding FailedCount}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="{loc:Loc Failed}" Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
        </Border>
      </UniformGrid>
      <DockPanel Margin="0,12,0,0">
        <ComboBox DockPanel.Dock="Right"
                  Width="180"
                  Margin="12,0,0,0"
                  SelectedValue="{Binding SelectedOutcomeFilter}"
                  SelectedValuePath="Tag">
          <ComboBoxItem Content="{loc:Loc All}" Tag="{x:Static viewModels:ImportResultOutcomeFilter.All}" />
          <ComboBoxItem Content="{loc:Loc ImportOutcomeAdded}" Tag="{x:Static viewModels:ImportResultOutcomeFilter.Added}" />
          <ComboBoxItem Content="{loc:Loc ImportOutcomeExactDuplicate}" Tag="{x:Static viewModels:ImportResultOutcomeFilter.ExactDuplicate}" />
          <ComboBoxItem Content="{loc:Loc ImportOutcomePossibleDuplicate}" Tag="{x:Static viewModels:ImportResultOutcomeFilter.PossibleDuplicate}" />
          <ComboBoxItem Content="{loc:Loc ImportOutcomeFailed}" Tag="{x:Static viewModels:ImportResultOutcomeFilter.Failed}" />
        </ComboBox>
        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="{loc:Loc SearchAllFields}" />
      </DockPanel>
    </StackPanel>
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Content="{loc:Loc RetryFailedImports}"
              Command="{Binding RetryFailedCommand}"
              MinWidth="130"
              Margin="0,0,8,0"
              ToolTip="{loc:Loc RetryFailedImportsTooltip}" />
      <Button Content="{loc:Loc Close}"
              MinWidth="90"
              Click="CloseClicked" />
    </StackPanel>
    <DataGrid ItemsSource="{Binding VisibleItems}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserSortColumns="True"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column">
      <DataGrid.Columns>
        <DataGridTextColumn Header="{loc:Loc File}" Binding="{Binding FileName}" Width="220">
          <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
              <Setter Property="ToolTip" Value="{Binding SourcePath}" />
              <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>
          </DataGridTextColumn.ElementStyle>
        </DataGridTextColumn>
        <DataGridTextColumn Header="{loc:Loc Type}"
                            Binding="{Binding FormatText}"
                            SortMemberPath="FormatText"
                            Width="70" />
        <DataGridTextColumn Header="{loc:Loc Size}"
                            Binding="{Binding SizeText}"
                            SortMemberPath="SizeBytesSort"
                            Width="90" />
        <DataGridTextColumn Header="{loc:Loc Duration}"
                            Binding="{Binding DurationText}"
                            SortMemberPath="DurationMillisecondsSort"
                            Width="90" />
        <DataGridTextColumn Header="{loc:Loc Outcome}"
                            Binding="{Binding Outcome, Converter={StaticResource ImportOutcomeToLocalizedStringConverter}}"
                            SortMemberPath="Outcome"
                            Width="180" />
        <DataGridTextColumn Header="{loc:Loc Message}"
                            Binding="{Binding Message, Converter={StaticResource ImportMessageToLocalizedStringConverter}}"
                            Width="2*" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>
