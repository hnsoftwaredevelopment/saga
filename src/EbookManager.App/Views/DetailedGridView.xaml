<UserControl x:Class="EbookManager.App.Views.DetailedGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:EbookManager.App.Converters"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             AllowDrop="True">
  <UserControl.Resources>
    <converters:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSourceConverter" />
  </UserControl.Resources>
  <syncfusion:SfDataGrid ItemsSource="{Binding VisibleBooks}"
                         SelectedItem="{Binding SelectedBook, Mode=TwoWay}"
                         AutoGenerateColumns="False"
                         AllowEditing="False"
                         AllowSorting="True"
                         NavigationMode="Row"
                         SelectionMode="Single"
                         HeaderRowHeight="36"
                         RowHeight="42"
                         AllowDrop="True">
    <syncfusion:SfDataGrid.Columns>
      <syncfusion:GridTemplateColumn HeaderText="Cover"
                                     MappingName="CoverBytes"
                                     Width="80">
        <syncfusion:GridTemplateColumn.CellTemplate>
          <DataTemplate>
            <Border Width="34"
                    Height="34"
                    Background="#FFE2E8F0"
                    CornerRadius="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
              <Image Source="{Binding CoverBytes, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                     Stretch="UniformToFill" />
            </Border>
          </DataTemplate>
        </syncfusion:GridTemplateColumn.CellTemplate>
      </syncfusion:GridTemplateColumn>
      <syncfusion:GridTextColumn HeaderText="Title"
                                 MappingName="Title"
                                 Width="220" />
      <syncfusion:GridTextColumn HeaderText="Authors"
                                 MappingName="Authors"
                                 Width="220" />
      <syncfusion:GridTextColumn HeaderText="Status"
                                 MappingName="ReadingStatus"
                                 Width="120" />
      <syncfusion:GridTextColumn HeaderText="E-reader"
                                 MappingName="EReader"
                                 Width="120" />
    </syncfusion:SfDataGrid.Columns>
  </syncfusion:SfDataGrid>
</UserControl>
