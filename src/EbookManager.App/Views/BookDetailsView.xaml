<UserControl x:Class="EbookManager.App.Views.BookDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:books="clr-namespace:EbookManager.Domain.Books;assembly=EbookManager.Domain"
             xmlns:converters="clr-namespace:EbookManager.App.Converters"
             xmlns:loc="clr-namespace:EbookManager.App.Localization">
  <UserControl.Resources>
    <converters:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSourceConverter" />
    <converters:BookSaveErrorToLocalizedStringConverter x:Key="BookSaveErrorToLocalizedStringConverter" />
  </UserControl.Resources>
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Top">
      <Border Background="#FFFFF3CD"
              CornerRadius="8"
              Padding="10"
              Margin="0,0,0,12">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasUnsavedChanges}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <TextBlock Text="{loc:Loc UnsavedChanges}"
                   Foreground="#FF7A4A00" />
      </Border>

      <Border Background="#FFF8D7DA"
              CornerRadius="8"
              Padding="10"
              Margin="0,0,0,12">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasSaveError}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <TextBlock Text="{Binding SaveErrorMessage, Converter={StaticResource BookSaveErrorToLocalizedStringConverter}}"
                   TextWrapping="Wrap"
                   Foreground="#FF842029" />
      </Border>

      <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
        <Button Command="{Binding SaveCommand}"
                MinWidth="70"
                Margin="0,0,8,0">
          <StackPanel Orientation="Horizontal">
            <Path Data="{StaticResource SaveIconGeometry}" Fill="{DynamicResource AccentBrush}" Width="16" Height="16" Stretch="Uniform" />
            <TextBlock Text="{loc:Loc Save}" Margin="7,0,0,0" />
          </StackPanel>
        </Button>
        <Button Command="{Binding UndoCommand}"
                MinWidth="70"
                Margin="0,0,8,0">
          <StackPanel Orientation="Horizontal">
            <Path Data="{StaticResource UndoIconGeometry}" Fill="{DynamicResource AccentBrush}" Width="16" Height="16" Stretch="Uniform" />
            <TextBlock Text="{loc:Loc Undo}" Margin="7,0,0,0" />
          </StackPanel>
        </Button>
        <Button Command="{Binding DeleteCommand}"
                MinWidth="70">
          <StackPanel Orientation="Horizontal">
            <Path Data="{StaticResource DeleteIconGeometry}" Fill="{DynamicResource AccentBrush}" Width="16" Height="16" Stretch="Uniform" />
            <TextBlock Text="{loc:Loc Delete}" Margin="7,0,0,0" />
          </StackPanel>
        </Button>
      </StackPanel>
    </StackPanel>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
      <Border Height="220"
              Background="#FFE2E8F0"
              CornerRadius="12"
              Margin="0,0,0,14">
        <Grid>
          <TextBlock Text="{loc:Loc Cover}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <Image Source="{Binding CoverBytes, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                 Stretch="Uniform" />
        </Grid>
      </Border>

      <TextBlock Text="{loc:Loc Title}" FontWeight="SemiBold" />
      <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" />
      <TextBlock Text="{loc:Loc Authors}" FontWeight="SemiBold" />
      <TextBox Text="{Binding AuthorsText, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" />
      <TextBlock Text="{loc:Loc Formats}" FontWeight="SemiBold" />
      <ItemsControl ItemsSource="{Binding FormatDetails}"
                    Margin="0,4,0,10">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{DynamicResource AppBackgroundBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="6,3"
                    Margin="0,0,0,6"
                    HorizontalAlignment="Left">
              <DockPanel LastChildFill="True">
                <TextBlock Text="{Binding DisplayText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
              </DockPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock Text="{loc:Loc Description}" FontWeight="SemiBold" />
      <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
               AcceptsReturn="True"
               Height="120"
               TextWrapping="Wrap"
               Margin="0,4,0,10" />
      <TextBlock Text="{loc:Loc Language}" FontWeight="SemiBold" />
      <TextBox Text="{Binding Language, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,4" />
      <TextBlock Text="{Binding LanguageDisplayName}"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 FontSize="12"
                 Margin="0,0,0,10" />
      <TextBlock Text="{loc:Loc Publisher}" FontWeight="SemiBold" />
      <TextBox Text="{Binding Publisher, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" />
      <TextBlock Text="{loc:Loc PublicationDate}" FontWeight="SemiBold" />
      <TextBox Text="{Binding PublicationDate, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" />
      <TextBlock Text="{loc:Loc Tags}" FontWeight="SemiBold" />
      <TextBox Text="{Binding TagsText, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" />
      <TextBlock Text="{loc:Loc Series}" FontWeight="SemiBold" />
      <TextBox Text="{Binding Series, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" />
      <TextBlock Text="{loc:Loc SeriesNumber}" FontWeight="SemiBold" />
      <TextBox Text="{Binding SeriesNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" />
      <TextBlock Text="{loc:Loc Isbn}" FontWeight="SemiBold" />
      <TextBox Text="{Binding Isbn, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" />
      <TextBlock Text="{loc:Loc Status}" FontWeight="SemiBold" />
      <ComboBox SelectedValue="{Binding ReadingStatus}"
                SelectedValuePath="Tag"
                Margin="0,4,0,10">
        <ComboBoxItem Content="{loc:Loc Unread}" Tag="{x:Static books:ReadingStatus.Unread}" />
        <ComboBoxItem Content="{loc:Loc Reading}" Tag="{x:Static books:ReadingStatus.Reading}" />
        <ComboBoxItem Content="{loc:Loc Read}" Tag="{x:Static books:ReadingStatus.Read}" />
      </ComboBox>
      <TextBlock Text="{loc:Loc DateAdded}" FontWeight="SemiBold" />
      <TextBox Text="{Binding CreatedUtcText, Mode=OneWay}"
               IsReadOnly="True"
               Margin="0,4,0,10" />
      <TextBlock Text="{loc:Loc LastModified}" FontWeight="SemiBold" />
      <TextBox Text="{Binding UpdatedUtcText, Mode=OneWay}"
               IsReadOnly="True"
               Margin="0,4,0,10" />
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</UserControl>
